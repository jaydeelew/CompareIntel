{
  "name": "@compareintel/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/ensure-dist-manifest.mjs",
    "dev": "vite",
    "dev:watch": "vite build --watch",
    "build": "vite build",
    "type-check": "tsc -b --noEmit",
    "test": "vitest run",
    "generate:icons": "node scripts/generate-icons.mjs",
    "package": "npm run build && node scripts/package.mjs"
  },
  "dependencies": {
    "@compareintel/core": "file:../compare-core",
    "@mozilla/readability": "^0.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.0",
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/webextension-polyfill": "^0.12.1",
    "@vitejs/plugin-react": "^4.3.4",
    "archiver": "^7.0.1",
    "typescript": "~5.7.2",
    "vite": "^6.0.5",
    "vitest": "^3.0.5"
  }
}
